<Window
        x:Class="ImportAndVisualiseTwoTables.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ImportAndVisualiseTwoTables"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Таблички"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        mc:Ignorable="d">
        <Window.Resources>
                <Style TargetType="DataGrid">
                        <Setter Property="Margin" Value="10" />
                        <Setter Property="FontFamily" Value="Times New Roman" />
                </Style>
        </Window.Resources>

        <!--  Корневой Grid: две секции MySQL и PostgreSQL  -->
        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  ═══════════════ MySQL секция ═══════════════  -->
                <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Label
                                Grid.Row="0"
                                FontFamily="Bahnschrift"
                                FontSize="30">
                                MySQL
                        </Label>

                        <Label
                                Grid.Row="1"
                                FontFamily="Bahnschrift"
                                FontSize="20">
                                1: Таблица выделяет Рабочих с помощью SQL запроса
                        </Label>

                        <DataGrid
                                x:Name="EmployeesDataGrid"
                                Grid.Row="2"
                                AutoGenerateColumns="False"
                                FontSize="20"
                                IsReadOnly="True">
                                <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding EmployeeId}" Header="ID" />
                                        <DataGridTextColumn Binding="{Binding FullName}" Header="FullName" />
                                        <DataGridTextColumn Binding="{Binding Passport}" Header="Паспорт" />
                                        <DataGridTextColumn Binding="{Binding Position}" Header="Должность" />
                                        <DataGridTextColumn Binding="{Binding CountPolicyholders}" Header="Количество застрахованных людей" />
                                </DataGrid.Columns>
                        </DataGrid>

                        <Label
                                Grid.Row="3"
                                FontFamily="Bahnschrift"
                                FontSize="20">
                                2: Таблица выделяет Claims Policyholders и выводит случившиеся происшествия
                        </Label>

                        <!--  Подписи LINQ / SQL  -->
                        <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        FontFamily="Bahnschrift"
                                        FontSize="16"
                                        Foreground="Gray">
                                        LINQ запрос
                                </Label>
                                <Label
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        FontFamily="Bahnschrift"
                                        FontSize="16"
                                        Foreground="Gray">
                                        SQL запрос
                                </Label>
                        </Grid>

                        <!--  Пара таблиц Claims  -->
                        <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DataGrid
                                        x:Name="ClaimsIncludedDataGrid"
                                        Grid.Column="0"
                                        AutoGenerateColumns="False"
                                        FontSize="20"
                                        IsReadOnly="True">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding ClaimId}" Header="ID" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.PolicyNumber}" Header="ID Потерпевшего" />
                                                <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.FullName}" Header="ФИО" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.BirthDate}" Header="День Рождения" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.Passport}" Header="Паспорт" />
                                                <DataGridTextColumn Binding="{Binding EventDate}" Header="Дата происшествия" />
                                                <DataGridTextColumn Binding="{Binding Payout}" Header="Выплаченные средства" />
                                        </DataGrid.Columns>
                                </DataGrid>

                                <DataGrid
                                        x:Name="ClaimsIncludedDataGridSQL"
                                        Grid.Column="1"
                                        AutoGenerateColumns="False"
                                        FontSize="20"
                                        IsReadOnly="True">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding ClaimId}" Header="ID" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.PolicyNumber}" Header="ID Потерпевшего" />
                                                <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.FullName}" Header="ФИО" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.BirthDate}" Header="День Рождения" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.Passport}" Header="Паспорт" />
                                                <DataGridTextColumn Binding="{Binding EventDate}" Header="Дата происшествия" />
                                                <DataGridTextColumn Binding="{Binding Payout}" Header="Выплаченные средства" />
                                        </DataGrid.Columns>
                                </DataGrid>
                        </Grid>
                </Grid>

                <!--  ═══════════════ PostgreSQL секция ═══════════════  -->
                <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Label
                                Grid.Row="0"
                                FontFamily="Bahnschrift"
                                FontSize="30">
                                PostgreSQL
                        </Label>

                        <Label
                                Grid.Row="1"
                                FontFamily="Bahnschrift"
                                FontSize="20">
                                1: Таблица выделяет Рабочих с помощью SQL запроса
                        </Label>

                        <DataGrid
                                x:Name="EmployeesPostgreDataGrid"
                                Grid.Row="2"
                                AutoGenerateColumns="False"
                                FontSize="20"
                                IsReadOnly="True">
                                <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding EmployeeId}" Header="ID" />
                                        <DataGridTextColumn Binding="{Binding FullName}" Header="FullName" />
                                        <DataGridTextColumn Binding="{Binding Passport}" Header="Паспорт" />
                                        <DataGridTextColumn Binding="{Binding Position}" Header="Должность" />
                                        <DataGridTextColumn Binding="{Binding CountPolicyholders}" Header="Количество застрахованных людей" />
                                </DataGrid.Columns>
                        </DataGrid>

                        <Label
                                Grid.Row="3"
                                FontFamily="Bahnschrift"
                                FontSize="20">
                                2: Таблица выделяет Claims Policyholders и выводит случившиеся происшествия
                        </Label>

                        <!--  Подписи LINQ / SQL  -->
                        <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        FontFamily="Bahnschrift"
                                        FontSize="16"
                                        Foreground="Gray">
                                        LINQ запрос
                                </Label>
                                <Label
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        FontFamily="Bahnschrift"
                                        FontSize="16"
                                        Foreground="Gray">
                                        SQL запрос
                                </Label>
                        </Grid>

                        <!--  Пара таблиц Claims  -->
                        <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <DataGrid
                                        x:Name="ClaimsPostgreIncludedDataGrid"
                                        Grid.Column="0"
                                        AutoGenerateColumns="False"
                                        FontSize="20"
                                        IsReadOnly="True">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding ClaimId}" Header="ID" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.PolicyNumber}" Header="ID Потерпевшего" />
                                                <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.FullName}" Header="ФИО" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.BirthDate}" Header="День Рождения" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.Passport}" Header="Паспорт" />
                                                <DataGridTextColumn Binding="{Binding EventDate}" Header="Дата происшествия" />
                                                <DataGridTextColumn Binding="{Binding Payout}" Header="Выплаченные средства" />
                                        </DataGrid.Columns>
                                </DataGrid>

                                <DataGrid
                                        x:Name="ClaimsPostgreIncludedDataGridSql"
                                        Grid.Column="1"
                                        AutoGenerateColumns="False"
                                        FontSize="20"
                                        IsReadOnly="True">
                                        <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding ClaimId}" Header="ID" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.PolicyNumber}" Header="ID Потерпевшего" />
                                                <DataGridTextColumn Binding="{Binding Description}" Header="Описание" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.FullName}" Header="ФИО" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.BirthDate}" Header="День Рождения" />
                                                <DataGridTextColumn Binding="{Binding PolicyNumberNavigation.Passport}" Header="Паспорт" />
                                                <DataGridTextColumn Binding="{Binding EventDate}" Header="Дата происшествия" />
                                                <DataGridTextColumn Binding="{Binding Payout}" Header="Выплаченные средства" />
                                        </DataGrid.Columns>
                                </DataGrid>
                        </Grid>
                </Grid>
        </Grid>
</Window>
